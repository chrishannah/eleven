{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"sitemap\", </feed/index.xml>; rel=\"alternate\"; type=\"application/rss+xml\"; title=\"Chris Hannah\", </api/micropub>; rel=\"micropub\", <https://webmention.io/chrishannah.me/webmention>; rel=\"webmention\", <https://indieauth.com/auth>; rel=\"authorization_endpoint\", <https://tokens.indieauth.com/token>; rel=\"token_endpoint\""
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/essays", "destination": "/essay/", "permanent": true },
    { "source": "/essays/", "destination": "/essay/", "permanent": true },
    { "source": "/links", "destination": "/link/", "permanent": true },
    { "source": "/links/", "destination": "/link/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/feed", "destination": "/feed/index.xml" },
    { "source": "/feed/essays", "destination": "/feed/essays/index.xml" },
    { "source": "/feed/posts", "destination": "/feed/posts/index.xml" },
    { "source": "/feed/micro", "destination": "/feed/micro/index.xml" },
    { "source": "/index.xml", "destination": "/feed/index.xml" },
    { "source": "/rss", "destination": "/feed/index.xml" },
    { "source": "/essays.xml", "destination": "/feed/essays/index.xml" },
    { "source": "/posts.xml", "destination": "/feed/posts/index.xml" },
    { "source": "/micro.xml", "destination": "/feed/micro/index.xml" },
    { "source": "/api/og", "destination": "/api/og" }
  ]
}
