{% set allPosts = collections.all | excludeDrafts %}

<div class="activity-right">
    <div class="section-head">
        <span class="section-title">Live Activity</span>
    </div>
    <div class="metric-row">
        <span class="metric-label">Current focus</span>
        {# <span class="metric-value live">{{ homepage.currentFocus }}</span> #}
        <script>
            fetch('https://minifocus.app/u/christest.txt')
                .then(r => r.text())
                .then(focus => {
                    document
                        .getElementById('focus')
                        .textContent = focus;
                });
        </script>
        <span id="focus"></span>
    </div>
    <div class="metric-row">
        <span class="metric-label">Last post</span>
        <span class="metric-value">{{ allPosts | daysSinceLastPost }}</span>
    </div>
    <div class="metric-row">
        <span class="metric-label">GitHub</span>
        <span class="metric-value">
            {% if github.commitsThisWeek != null %}{{ github.commitsThisWeek }} commits/wk{% else %}--{% endif %}
        </span>
    </div>
    <div class="metric-row">
        <span class="metric-label">Page views</span>
        <span class="metric-value" id="page-views">--</span>
    </div>
</div>
