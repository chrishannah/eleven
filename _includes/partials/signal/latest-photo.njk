<div class="secondary-section">
    <div class="section-head">
        <span class="section-title">Latest Photo</span>
    </div>
    {% if instagram and instagram.imageUrl %}
    <a href="{{ instagram.permalink }}" class="polaroid" target="_blank" rel="noopener">
        <div class="polaroid-image">
            <img src="{{ instagram.imageUrl }}" alt="{{ instagram.caption or 'Latest Instagram photo' }}" loading="lazy">
        </div>
        {% if instagram.caption %}
        <div class="polaroid-text">
            <span>{{ instagram.caption }}</span>
        </div>
        {% endif %}
        <div class="polaroid-caption">
            <span class="polaroid-handle">@{{ homepage.instagram.username }}</span>
            {% if instagram.timestamp %}
            <span class="polaroid-time">{{ instagram.timestamp | relativeTime }}</span>
            {% endif %}
        </div>
    </a>
    {% else %}
    <a href="https://instagram.com/{{ homepage.instagram.username }}" class="polaroid" target="_blank" rel="noopener">
        <div class="polaroid-image">
            [Photo]
        </div>
        <div class="polaroid-caption">
            <span class="polaroid-handle">@{{ homepage.instagram.username }}</span>
        </div>
    </a>
    {% endif %}
    <script>
        document.querySelector('.polaroid').style.setProperty('--polaroid-rotation', (Math.random() * 6 - 3).toFixed(1) + 'deg');
    </script>
</div>
