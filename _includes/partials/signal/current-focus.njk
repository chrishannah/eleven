<div class="secondary-section">
    <div class="section-head">
        <span class="section-title">Current Focus</span>
    </div>
    <div class="focus-content" id="focus-container">
        <script>
            (function() {
                var pref = localStorage.getItem('theme-preference') || 'auto';
                var mode = pref;
                if (pref === 'auto') {
                    mode = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
                }
                var s = document.createElement('script');
                s.src = 'https://minifocus.app/embed/chris.js';
                s.setAttribute('data-color-mode', mode);
                document.getElementById('focus-container').appendChild(s);
            })();
        </script>
        <noscript>
            <p><a href="https://minifocus.app/u/chris">View focus on Minifocus</a></p>
        </noscript>
    </div>
</div>
