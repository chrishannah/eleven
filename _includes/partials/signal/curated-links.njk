{% set linkPosts = collections.link | excludeDrafts | reverse %}
{% set recentLinks = linkPosts | limit(5) %}

<div class="section-head">
    <span class="section-title">-> Curated Links</span>
    <span class="section-meta">{{ linkPosts | length }} shared</span>
</div>
{% if recentLinks | length > 0 %}
{% for post in recentLinks %}
<div class="signal-post-item">
    <div class="post-date">
        <span class="day">{{ post.data.date | dayNumber }}</span>
        <span class="month-year">{{ post.data.date | monthYear }}</span>
    </div>
    <div class="post-content">
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p class="post-excerpt">{{ post.content | excerpt | safe }}</p>
    </div>
    <span class="post-tag">Link</span>
</div>
{% endfor %}
{% else %}
<div class="signal-post-item" style="justify-content: center;">
    <span style="color: var(--text-muted); font-size: 0.8rem;">No links yet</span>
</div>
{% endif %}
