---
layout: layouts/base
---

{% set postNum = page.url | postNumber(collections.all) %}
{% set displayTags = (tags or []) | filterTagList %}

<article class="h-entry music-post" data-type="music">
    {% if artwork %}
        <img src="{{ artwork }}" alt="{{ title }} by {{ artist }}" class="music-artwork"/>
    {% endif %}

    <h1 class="p-name">
        <a href="{{ url | url }}">{{ title }}</a>
    </h1>

    <div class="post-meta">
        <p>
            {% if postNum %}<span class="post-number">#{{ postNum }}</span>{% endif %}
            <a class="type" href="/music/">Music</a>
            <span class="sep">·</span>
            {% if artist %}<span class="music-artist">{{ artist }}</span> <span class="sep">·</span> {% endif %}
            <time class="dt-published" datetime="{{ date }}">{{ date | displayDate }}</time>
        </p>
    </div>

    {% if musicUrl %}
        <div class="music-listen">
            <a href="{{ musicUrl }}" class="music-link" target="_blank" rel="noopener">Listen →</a>
        </div>
    {% endif %}

    <div class="content">
        {{ content | safe }}
    </div>

    {% if displayTags.length %}
    <div class="post-tags">
        {% for tag in displayTags %}
        <span class="post-tag">{{ tag }}</span>
        {% endfor %}
    </div>
    {% endif %}

    {% include "partials/post-footer.njk" %}
</article>

{% include "partials/transmit.njk" %}
