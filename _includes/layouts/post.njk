---
layout: layouts/base
---

{% set postTags = tags or [] %}
{% set postTypeKey = "post" %}
{% set postType = "Post" %}
{% set postTypeUrl = "/post/" %}
{% if 'essay' in postTags %}
    {% set postTypeKey = "essay" %}{% set postType = "Essay" %}{% set postTypeUrl = "/essay/" %}
{% elif 'link' in postTags %}
    {% set postTypeKey = "link" %}{% set postType = "Link" %}{% set postTypeUrl = "/link/" %}
{% elif 'micro' in postTags %}
    {% set postTypeKey = "micro" %}{% set postType = "Micro" %}{% set postTypeUrl = "/micro/" %}
{% elif 'photography' in postTags %}
    {% set postTypeKey = "photography" %}{% set postType = "Photo" %}{% set postTypeUrl = "/photography/" %}
{% elif 'quote' in postTags %}
    {% set postTypeKey = "quote" %}{% set postType = "Quote" %}{% set postTypeUrl = "" %}
{% elif 'music' in postTags %}
    {% set postTypeKey = "music" %}{% set postType = "Music" %}{% set postTypeUrl = "/music/" %}
{% elif 'note' in postTags %}
    {% set postTypeKey = "note" %}{% set postType = "Note" %}{% set postTypeUrl = "/note/" %}
{% endif %}

{% set postNum = page.url | postNumber(collections.all) %}
{% set displayTags = postTags | filterTagList %}

<article class="h-entry" data-type="{{ postTypeKey }}">
    {% if image and postTypeKey != "note" %}
        <img src="{{ image }}" alt="" class="list-card-image"/>
    {% endif %}

    {% if title %}
    <h1 class="p-name">
        <a href="{{ url | url }}">{{ title }}</a>
    </h1>
    {% endif %}

    {% if image and postTypeKey == "note" %}
        <img src="{{ image }}" alt="" class="list-card-image"/>
    {% endif %}

    <div class="post-meta">
        <p>
            {% if postNum %}<span class="post-number">#{{ postNum }}</span>{% endif %}
            {% if postTypeUrl %}<a class="type" href="{{ postTypeUrl }}">{{ postType }}</a>{% else %}<span class="type">{{ postType }}</span>{% endif %}
            <span class="sep">·</span>
            <time class="dt-published" datetime="{{ date }}">{{ date | displayDate }}</time>
        </p>
    </div>

    <div class="content">
        {{ content | safe }}
    </div>

    {% if displayTags.length %}
    <div class="post-tags">
        {% for tag in displayTags %}
        <span class="post-tag">{{ tag }}</span>
        {% endfor %}
    </div>
    {% endif %}

    {% include "partials/post-footer.njk" %}
</article>

{% include "partials/transmit.njk" %}
