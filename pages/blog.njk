---
layout: layouts/home-steno
tags:
  - nav
navtitle: Posts
title: ''
pagination:
  data: collections.all
  size: 10
  reverse: true
  alias: posts
permalink: "{{ pagination.pageNumber | getBlogPermalinkSuffixFromPageNum }}"
eleventyExcludeFromCollections: true
---

{% for post in posts %}
  {% set postTags = post.data.tags or [] %}
  {% if 'essay' in postTags %}
      {% set postType = "Essay" %}
  {% elif 'link' in postTags %}
      {% set postType = "Link" %}
  {% elif 'micro' in postTags %}
      {% set postType = "Micro" %}
  {% elif 'photography' in postTags %}
      {% set postType = "Photo" %}
  {% elif 'quote' in postTags %}
      {% set postType = "Quote" %}
  {% elif 'music' in postTags %}
      {% set postType = "Music" %}
  {% else %}
      {% set postType = "Post" %}
  {% endif %}

<article class="post-entry h-entry">
    <div class="entry-date"><span class="type">{{ postType }}</span> — <time class="dt-published" datetime="{{ post.data.date }}">{{ post.data.date | displayDate }}</time></div>
    {% if 'music' in postTags and post.data.artwork %}
        <img src="{{ post.data.artwork }}" alt="" class="music-artwork"/>
    {% elif post.data.image %}
        <img src="{{ post.data.image }}" alt="" class="list-card-image"/>
    {% endif %}
    {% if post.data.title %}
        {% if 'link' in postTags and post.data.link %}
        <h2 class="p-name"><a href="{{ post.data.link }}">{{ post.data.title }} →</a></h2>
        {% else %}
        <h2 class="p-name"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        {% endif %}
    {% endif %}
    <div class="entry-excerpt content">
        {{ post.content | safe }}
    </div>
    <div class="post-meta">
        <a style="display: none;" rel="author" class="p-author h-card" href="{{ author.url }}">{{ author.name }}</a>
        <a class="u-url" href="{{ post.url | url }}">Permalink</a>
    </div>
</article>
{% endfor %}

<nav class="pagination">
  {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}">← Newer</a>
  {% else %}
    <span class="disabled">← Newer</span>
  {% endif %}

  {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}">Older →</a>
  {% else %}
    <span class="disabled">Older →</span>
  {% endif %}
</nav>
