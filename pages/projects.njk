---
layout: layouts/base
tags:
  - nav
navtitle: Projects
title: Projects
permalink: /projects/
---

<h1>Projects</h1>

<p class="intro-text">Things I'm building, writing, and maintaining.</p>

{% for site in external %}
<div class="project-item">
    <div class="project-heading">
        {% if site.favicon %}
        <img src="{{ site.favicon }}" alt="" class="project-icon">
        {% endif %}
        <h2><a href="{{ site.url }}" target="_blank" rel="noopener">{{ site.name }}</a></h2>
    </div>
    <p class="project-description">{{ site.description }}</p>
    <div class="project-links">
        <a href="{{ site.url }}" target="_blank" rel="noopener">{{ site.url | replace("https://", "") }} →</a>
    </div>
</div>
{% endfor %}

{% for project in projects %}
<div class="project-item">
    <div class="project-heading">
        {% if project.iconUrl %}
        <img src="{{ project.iconUrl }}" alt="" class="project-icon">
        {% endif %}
        {% if project.status !== "Live" %}
        <span class="project-status">{{ project.status }}</span>
        {% endif %}
        <h2>
            {% if project.url %}
                <a href="{{ project.url }}" target="_blank" rel="noopener">{{ project.name }}</a>
            {% else %}
                {{ project.name }}
            {% endif %}
        </h2>
    </div>
    <p class="project-description">{{ project.description }}</p>
    {% if project.tags %}
    <div class="project-tags">
        {% for tag in project.tags %}
            <span class="project-tag">{{ tag }}</span>
        {% endfor %}
    </div>
    {% endif %}
    <div class="project-links">
        {% if project.url %}
            <a href="{{ project.url }}" target="_blank" rel="noopener">{{ project.url | replace("https://", "") | replace("http://", "") }} →</a>
        {% endif %}
        {% if project.github %}
            <a href="{{ project.github }}" target="_blank" rel="noopener">GitHub →</a>
        {% endif %}
    </div>
</div>
{% endfor %}
